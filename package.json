  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,yellow \"NEXT_DISABLE_TURBOPACK=1 next dev\" \"cd backend && npm run dev\"",
    "dev:frontend": "NEXT_DISABLE_TURBOPACK=1 next dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:webpack": "NODE_OPTIONS='--no-warnings' NEXT_DISABLE_TURBOPACK=1 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
